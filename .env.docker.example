DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/biometric

EMBEDDING_BACKEND=onnx
EMBEDDING_DIM=512
DEFAULT_PIPELINE=pretrained
ENABLE_PRETRAINED_PIPELINE=true
ENABLE_CUSTOM_PIPELINE=true
PRETRAINED_BACKEND=onnx
CUSTOM_BACKEND=onnx

MODEL_NAME=buffalo_l

# Docker profile expects the trained checkpoint to be mounted into /app/training/outputs.
TORCH_MODEL_PATH=/app/training/outputs/checkpoint_epoch_001.pth
TORCH_MODEL_ARCH=ir50
TORCH_INPUT_SIZE=112
TORCH_DEVICE=cpu
TORCH_USE_FP16=false
TORCH_NORM_EMBEDDINGS=true

ONNX_MODEL_PATH=
ONNX_DETECTOR_PATH=/app/model_bundle/models/det_10g.onnx
ONNX_EMBEDDER_PATH=/app/model_bundle/models/w600k_r50.onnx

MATCH_THRESHOLD=0.4
STRICT_SINGLE_FACE=true
DETECTION_BACKEND=none
ALLOW_CENTER_CROP=false
CUSTOM_DETECTION_BACKEND=opencv
CUSTOM_ALLOW_CENTER_CROP=true
MIN_DET_SCORE=0.5

INDEX_TYPE=hnsw
INDEX_PATH=/app/data/index/current.faiss
PRETRAINED_INDEX_PATH=/app/data/index/pretrained.faiss
CUSTOM_INDEX_PATH=/app/data/index/custom.faiss
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=64
IVFPQ_NLIST=100
IVFPQ_M=16
IVFPQ_NBITS=8

API_KEY=
CORS_ORIGINS=*
AUTO_SAVE_INDEX=true
LOG_LEVEL=INFO
SEED=42
TESTING=false

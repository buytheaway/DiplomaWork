DATABASE_URL=sqlite+pysqlite:///C:/Users/mukha/OneDrive/Documents/GitHub/DiplomaWork/backend/backend_local.db

# Local dual-pipeline profile
EMBEDDING_BACKEND=onnx
EMBEDDING_DIM=512
DEFAULT_PIPELINE=pretrained
ENABLE_PRETRAINED_PIPELINE=true
ENABLE_CUSTOM_PIPELINE=true
PRETRAINED_BACKEND=onnx
CUSTOM_BACKEND=torch

MODEL_NAME=buffalo_l

# Local profile expects an existing trained checkpoint.
TORCH_MODEL_PATH=training/outputs/checkpoint_epoch_005.pth
TORCH_MODEL_ARCH=ir50
TORCH_INPUT_SIZE=112
TORCH_DEVICE=cuda
TORCH_USE_FP16=true
TORCH_NORM_EMBEDDINGS=true

ONNX_MODEL_PATH=
ONNX_DETECTOR_PATH=models/buffalo_l/det_10g.onnx
ONNX_EMBEDDER_PATH=models/buffalo_l/w600k_r50.onnx

MATCH_THRESHOLD=0.4

# Search supports multiple faces; enroll remains strict.
STRICT_SINGLE_FACE=true
DETECTION_BACKEND=none
ALLOW_CENTER_CROP=false
CUSTOM_DETECTION_BACKEND=opencv
CUSTOM_ALLOW_CENTER_CROP=true
MIN_DET_SCORE=0.5

INDEX_TYPE=hnsw
INDEX_PATH=backend/data/index/local.faiss
PRETRAINED_INDEX_PATH=backend/data/index/pretrained.faiss
CUSTOM_INDEX_PATH=backend/data/index/custom.faiss
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=64
IVFPQ_NLIST=100
IVFPQ_M=16
IVFPQ_NBITS=8

API_KEY=
CORS_ORIGINS=*
AUTO_SAVE_INDEX=true
LOG_LEVEL=INFO
SEED=42
TESTING=false

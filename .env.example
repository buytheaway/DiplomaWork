# Example values are placeholders. Do not use them for production or demos with real biometric data.
# Generate API keys:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Generate encryption keys:
#   python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"

# Database
DATABASE_URL=postgresql+psycopg2://REPLACE_WITH_POSTGRES_USER:REPLACE_WITH_POSTGRES_PASSWORD@db:5432/biometric
# DATABASE_URL=sqlite+pysqlite:///backend/backend_local.db

# Pipeline selection
EMBEDDING_BACKEND=dummy
EMBEDDING_DIM=512
DEFAULT_PIPELINE=pretrained
ENABLE_PRETRAINED_PIPELINE=true
ENABLE_CUSTOM_PIPELINE=true
PRETRAINED_BACKEND=onnx
CUSTOM_BACKEND=onnx

# Models
MODEL_NAME=buffalo_l
# Optional custom model path. Set this to a trained checkpoint to keep the custom pipeline available.
TORCH_MODEL_PATH=training/outputs/checkpoint_epoch_001.pth
TORCH_MODEL_ARCH=ir50
TORCH_INPUT_SIZE=112
TORCH_DEVICE=cpu
TORCH_USE_FP16=false
TORCH_NORM_EMBEDDINGS=true
ONNX_MODEL_PATH=
ONNX_DETECTOR_PATH=
ONNX_EMBEDDER_PATH=

# Matching
MATCH_THRESHOLD=0.4

# Face detection / alignment
# Search supports multiple faces for every available pipeline.
# Enroll still enforces STRICT_SINGLE_FACE by default.
STRICT_SINGLE_FACE=true
DETECTION_BACKEND=none
ALLOW_CENTER_CROP=false
CUSTOM_DETECTION_BACKEND=opencv
CUSTOM_ALLOW_CENTER_CROP=true
MIN_DET_SCORE=0.5

# Vector index
INDEX_TYPE=hnsw
INDEX_PATH=backend/data/index/current.faiss
PRETRAINED_INDEX_PATH=backend/data/index/pretrained.faiss
CUSTOM_INDEX_PATH=backend/data/index/custom.faiss
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=64
IVFPQ_NLIST=100
IVFPQ_M=16
IVFPQ_NBITS=8

# Security / runtime
API_KEY=REPLACE_WITH_GENERATED_OPERATOR_API_KEY
ADMIN_API_KEY=REPLACE_WITH_GENERATED_ADMIN_API_KEY
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
MAX_UPLOAD_BYTES=10485760
ALLOWED_IMAGE_CONTENT_TYPES=image/jpeg,image/png,image/webp,image/bmp
DATA_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_URLSAFE_BASE64_KEY
SNAPSHOT_ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_URLSAFE_BASE64_KEY
AUDIT_RETENTION_DAYS=30
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SEARCH_PER_MIN=60
RATE_LIMIT_ENROLL_PER_MIN=20
RATE_LIMIT_ADMIN_PER_MIN=10
AUTO_SAVE_INDEX=true
LOG_LEVEL=INFO
SEED=42
TESTING=false

# ── Database ──────────────────────────────────────────────────────────
# Docker / Postgres:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/biometric
# Local / SQLite (uncomment):
# DATABASE_URL=sqlite+pysqlite:///backend/backend_local.db

# ── Embedding extractor (plugin) ─────────────────────────────────────
# "dummy" — no ML deps, always works (tests / demo)
# "insightface" — requires: pip install insightface onnxruntime
# "torch" — requires: pip install torch opencv-python-headless
# "onnx" — requires: pip install onnxruntime opencv-python-headless
EMBEDDING_BACKEND=dummy
EMBEDDING_DIM=512

# InsightFace-specific
MODEL_NAME=buffalo_l

# Torch-specific
TORCH_MODEL_PATH=
TORCH_MODEL_ARCH=ir50
TORCH_INPUT_SIZE=112
TORCH_DEVICE=cpu
TORCH_USE_FP16=false
TORCH_NORM_EMBEDDINGS=true

# ONNX-specific
ONNX_MODEL_PATH=

# ── Face detection / quality ─────────────────────────────────────────
STRICT_SINGLE_FACE=true
DETECTION_BACKEND=none
ALLOW_CENTER_CROP=false
MIN_DET_SCORE=0.5

# ── Vector index ─────────────────────────────────────────────────────
INDEX_TYPE=hnsw
INDEX_PATH=backend/data/index/current.faiss
HNSW_M=32
HNSW_EF_CONSTRUCTION=200
HNSW_EF_SEARCH=64
IVFPQ_NLIST=100
IVFPQ_M=16
IVFPQ_NBITS=8

# ── Runtime ──────────────────────────────────────────────────────────
AUTO_SAVE_INDEX=true
LOG_LEVEL=INFO
SEED=42
TESTING=false
